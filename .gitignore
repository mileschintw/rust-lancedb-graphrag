# ==============================================================================
# Lancet - Git Ignore Configuration
# ==============================================================================

# OS / System Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# IDEs & Editor Configuration
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swo
*.swn
.project
.classpath
.settings/
.factorypath

# Environment & Secrets
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.local

# Databases & Persistent Local Storage
# ------------------------------------------------------------------------------
# PostgreSQL volume data
pgdata/
postgres-data/
db_data/
# LanceDB embedded database storage
lancedb/
.lancedb/
# Local database files
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-shm
*.db-wal

# Go (API Gateway)
# ------------------------------------------------------------------------------
# Compiled binaries
gateway/gateway
gateway/gateway.exe
bin/
.tmp-go-cache/
# Test/coverage/profile outputs
*.test
*.out
cover.out
coverage.txt
profile.out

# Rust (RAG Engine)
# ------------------------------------------------------------------------------
# Cargo build artifacts
target/
# Cargo backups and source control files
**/*.rs.bk

# Python (Evaluation Suite)
# ------------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
# Distribution / packaging
.eggs/
.eggs-info/
*.egg-info/
# Virtual Environments
venv/
.venv/
env/
ENV/
.env/
# Testing / Coverage
.cache/
.pytest_cache/
.tox/
.coverage
.coverage.*
htmlcov/
nosetests.xml
coverage.xml
*.cover
.mypy_cache/
.dmypy.json
dmypy.json

# Tracing & Logging
# ------------------------------------------------------------------------------
logs/
*.log
